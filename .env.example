# ALLOWED_GOOGLE_EMAILS=you@gmail.com,friend@gmail.com

CRON_SECRET=any-random-string-you-choose
DATABASE_URL=./data/movietracker.db
CHECK_INTERVAL_MINUTES=5
NEXT_PUBLIC_APP_URL=http://localhost:3000
